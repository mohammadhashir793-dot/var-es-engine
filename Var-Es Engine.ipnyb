      "source": [
        "## 7. Visualizations & Risk Dashboard"
      ],
      "id": "NAtfOWKgOXRW"
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "RQJgYIZPOXRW"
      },
      "outputs": [],
      "source": [
        "# ==============================================================\n",
        "# CELL 7A: PORTFOLIO RETURN DISTRIBUTION WITH VaR / ES OVERLAY\n",
        "# ==============================================================\n",
        "\n",
        "def plot_return_distribution(returns: pd.Series, engine: VaREngine, confidence: float):\n",
        "    hist_result = engine.historical(confidence)\n",
        "    param_result = engine.parametric(confidence)\n",
        "\n",
        "    fig, ax = plt.subplots(figsize=(11, 6))\n",
        "    ax.hist(returns * 100, bins=80, color=\"#4C72B0\", alpha=0.75, density=True,\n",
        "            label=\"Empirical Daily Returns\")\n",
        "\n",
        "    # Overlay fitted normal distribution for visual comparison\n",
        "    x = np.linspace(returns.min(), returns.max(), 500)\n",
        "    ax.plot(x * 100, stats.norm.pdf(x, returns.mean(), returns.std()),\n",
        "            color=\"black\", lw=1.5, ls=\"--\", label=\"Fitted Normal Distribution\")\n",
        "\n",
        "    ax.axvline(-hist_result.var_pct * 100, color=\"#C44E52\", lw=2,\n",
        "               label=f\"Historical VaR {int(confidence*100)}%: {hist_result.var_pct*100:.2f}%\")\n",
        "    ax.axvline(-hist_result.es_pct * 100, color=\"#8172B2\", lw=2, ls=\":\",\n",
        "               label=f\"Historical ES {int(confidence*100)}%: {hist_result.es_pct*100:.2f}%\")\n",
        "    ax.axvline(-param_result.var_pct * 100, color=\"#DD8452\", lw=1.5, ls=\"-.\",\n",
        "               label=f\"Parametric VaR {int(confidence*100)}%: {param_result.var_pct*100:.2f}%\")\n",
        "\n",
        "    ax.set_title(f\"Portfolio Daily Return Distribution — Risk Overlay ({int(confidence*100)}% Confidence)\")\n",
        "    ax.set_xlabel(\"Daily Return (%)\")\n",
        "    ax.set_ylabel(\"Density\")\n",
        "    ax.legend(loc=\"upper left\", fontsize=9)\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "for cl in CONFIG[\"confidence_levels\"]:\n",
        "    plot_return_distribution(portfolio_returns, engine, cl)\n"
      ],
      "id": "RQJgYIZPOXRW"
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "d5oXX2e7OXRW"
      },
      "outputs": [],
      "source": [
        "# ==============================================================\n",
        "# CELL 7B: ROLLING VaR VS. ACTUAL RETURNS WITH BREACH MARKERS\n",
        "# ==============================================================\n",
        "\n",
        "def plot_rolling_backtest(bt_df: pd.DataFrame, confidence: float):\n",
        "    fig, ax = plt.subplots(figsize=(12, 6))\n",
        "\n",
        "    ax.plot(bt_df.index, bt_df[\"actual_return\"] * 100, color=\"#4C72B0\",\n",
        "            lw=0.8, alpha=0.8, label=\"Actual Daily Return\")\n",
        "    ax.plot(bt_df.index, -bt_df[\"VaR_forecast\"] * 100, color=\"#C44E52\",\n",
        "            lw=1.4, label=f\"Rolling VaR Forecast ({int(confidence*100)}%)\")\n",
        "\n",
        "    breaches = bt_df[bt_df[\"breach\"]]\n",
        "    ax.scatter(breaches.index, breaches[\"actual_return\"] * 100, color=\"red\",\n",
        "               s=35, zorder=5, label=f\"VaR Breach (n={len(breaches)})\")\n",
        "\n",
        "    ax.set_title(f\"Rolling Historical VaR Backtest — {int(confidence*100)}% Confidence\")\n",
        "    ax.set_xlabel(\"Date\")\n",
        "    ax.set_ylabel(\"Return (%)\")\n",
        "    ax.legend(loc=\"lower left\", fontsize=9)\n",
        "    ax.xaxis.set_major_formatter(mdates.DateFormatter(\"%Y-%m\"))\n",
        "    fig.autofmt_xdate()\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "for cl in CONFIG[\"confidence_levels\"]:\n",
        "    plot_rolling_backtest(backtest_results[cl], cl)\n"
      ],
      "id": "d5oXX2e7OXRW"
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "VuZQ9-mWOXRW"
      },
      "outputs": [],
      "source": [
        "# ==============================================================\n",
        "# CELL 7C: METHOD COMPARISON BAR CHART (VaR & ES ACROSS METHODOLOGIES)\n",
        "# ==============================================================\n",
        "\n",
        "def plot_method_comparison(summary_df: pd.DataFrame):\n",
        "    fig, axes = plt.subplots(1, 2, figsize=(14, 6), sharey=False)\n",
        "\n",
        "    for ax, metric, title in zip(axes, [\"VaR (%)\", \"ES (%)\"],\n",
        "                                  [\"Value-at-Risk by Method\", \"Expected Shortfall by Method\"]):\n",
        "        pivot = summary_df.pivot(index=\"Method\", columns=\"Confidence\", values=metric)\n",
        "        pivot.plot(kind=\"bar\", ax=ax, color=[\"#4C72B0\", \"#C44E52\"], width=0.7)\n",
        "        ax.set_title(title)\n",
        "        ax.set_ylabel(\"Loss (% of Portfolio)\")\n",
        "        ax.set_xlabel(\"\")\n",
        "        ax.tick_params(axis=\"x\", rotation=20)\n",
        "        ax.legend(title=\"Confidence\")\n",
        "\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "plot_method_comparison(risk_summary)\n"
      ],
      "id": "VuZQ9-mWOXRW"
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "gZgQ-eG6OXRX"
      },
      "outputs": [],
      "source": [
        "# ==============================================================\n",
        "# CELL 7D: PORTFOLIO CUMULATIVE RETURN & DRAWDOWN (RISK CONTEXT)\n",
        "# ==============================================================\n",
        "\n",
        "def plot_cumulative_and_drawdown(returns: pd.Series):\n",
        "    cumulative = (1 + returns).cumprod()\n",
        "    running_max = cumulative.cummax()\n",
        "    drawdown = (cumulative - running_max) / running_max\n",
        "\n",
        "    fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(12, 8), sharex=True,\n",
        "                                    gridspec_kw={\"height_ratios\": [2, 1]})\n",
        "\n",
        "    ax1.plot(cumulative.index, cumulative.values, color=\"#4C72B0\", lw=1.3)\n",
        "    ax1.set_title(\"Portfolio Cumulative Growth (Backtest Period)\")\n",
        "    ax1.set_ylabel(\"Growth of $1\")\n",
        "\n",
        "    ax2.fill_between(drawdown.index, drawdown.values * 100, 0, color=\"#C44E52\", alpha=0.6)\n",
        "    ax2.set_title(f\"Drawdown (Max: {drawdown.min()*100:.2f}%)\")\n",
        "    ax2.set_ylabel(\"Drawdown (%)\")\n",
        "    ax2.set_xlabel(\"Date\")\n",
        "\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "plot_cumulative_and_drawdown(portfolio_returns)\n"
      ],
      "id": "gZgQ-eG6OXRX"
    },
