      "source": [
        "# ==============================================================\n",
        "# CELL 8: FINAL CONSOLIDATED RISK REPORT\n",
        "# ==============================================================\n",
        "\n",
        "def generate_risk_report(cfg: dict, summary_df: pd.DataFrame, kupiec: dict) -> None:\n",
        "    print(\"=\" * 70)\n",
        "    print(\" PORTFOLIO VALUE-AT-RISK & EXPECTED SHORTFALL — RISK REPORT\")\n",
        "    print(\"=\" * 70)\n",
        "    print(f\" Portfolio Value:      ${cfg['portfolio_value']:,.0f}\")\n",
        "    print(f\" Holdings:             {', '.join(cfg['tickers'])}\")\n",
        "    print(f\" Weights:              {cfg['weights']}\")\n",
        "    print(f\" Analysis Period:      {cfg['start_date']} -> {cfg['end_date'] or 'today'}\")\n",
        "    print(f\" Monte Carlo Paths:    {cfg['mc_simulations']:,}\")\n",
        "    print(\"-\" * 70)\n",
        "    print(summary_df.to_string(index=False))\n",
        "    print(\"-\" * 70)\n",
        "    for cl, res in kupiec.items():\n",
        "        status = \"PASS\" if res[\"model_accepted_at_95pct\"] else \"FAIL\"\n",
        "        print(f\" Kupiec Backtest @ {int(cl*100)}%:  {res['n_breaches']} breaches / \"\n",
        "              f\"{res['n_observations']} obs  (expected {res['expected_breaches']})  \"\n",
        "              f\"-> p-value={res['p_value']}  [{status}]\")\n",
        "    print(\"=\" * 70)\n",
        "\n",
        "\n",
        "generate_risk_report(CONFIG, risk_summary, kupiec_results)\n",
        "\n",
        "# Persist results for downstream use / GitHub artifact\n",
        "risk_summary.to_csv(\"var_es_summary.csv\", index=False)\n",
        "print(\"\\nSaved detailed results to 'var_es_summary.csv'\")\n"
      ],
      "id": "pTK1xJnOOXRX"
    },
    {
      "cell_type": "markdown",
